{
  "name": "mail-samurai",
  "version": "0.1.0",
  "description": "Electron app that polls multiple IMAP email accounts and categorizes messages with AI.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Nicolás López",
    "email": "nicolaslopezj@me.com",
    "url": "https://github.com/nicolaslopezj"
  },
  "license": "MIT",
  "homepage": "https://github.com/nicolaslopezj/mail-samurai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolaslopezj/mail-samurai.git"
  },
  "bugs": {
    "url": "https://github.com/nicolaslopezj/mail-samurai/issues"
  },
  "scripts": {
    "lint": "biome check src agent",
    "format": "biome format --write src agent",
    "check": "biome check --write src agent",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "agent:serve": "electron-vite build && node agent/server.mjs",
    "agent": "node agent/cli.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
